# Signaltower local environment — copy to .env and fill in the real values.
# .env is gitignored. Secret should also live in 1Password
# ("homelab — signaltower API key" Secure Note) as cloud backup.

# API key for X-API-Key header / ?key= query param.
# Production key on rbhapp01: sudo cat /etc/signaltower/env
SIGNALTOWER_API_KEY=

# Production server URL (for outgoing curl tests from this Mac).
SIGNALTOWER_URL=http://172.16.47.242:5000
